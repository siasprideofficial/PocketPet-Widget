<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Cat Sleep State Vector Drawable
    Curled up sleeping cat
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="100dp"
    android:height="100dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    
    <!-- Body (curled up) -->
    <path
        android:pathData="M40,140 Q40,100 100,100 Q160,100 160,140 Q160,175 100,175 Q40,175 40,140 Z"
        android:fillColor="#F59E0B"/>
    
    <!-- Head -->
    <path
        android:pathData="M45,110 A35,35 0 1,1 115,110 A35,35 0 1,1 45,110 Z"
        android:fillColor="#F59E0B"/>
    
    <!-- Left Ear -->
    <path
        android:pathData="M50,90 L55,60 L70,85 Z"
        android:fillColor="#F59E0B"/>
    <path
        android:pathData="M53,87 L58,65 L68,83 Z"
        android:fillColor="#FFB6C1"/>
    
    <!-- Right Ear -->
    <path
        android:pathData="M105,85 L100,55 L85,80 Z"
        android:fillColor="#F59E0B"/>
    <path
        android:pathData="M102,83 L98,60 L88,78 Z"
        android:fillColor="#FFB6C1"/>
    
    <!-- Closed Eyes (curved lines) -->
    <path
        android:pathData="M55,105 Q65,98 75,105"
        android:strokeColor="#333333"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M85,102 Q95,95 105,102"
        android:strokeColor="#333333"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    
    <!-- Nose -->
    <path
        android:pathData="M78,115 A4,3 0 1,1 86,115 A4,3 0 1,1 78,115 Z"
        android:fillColor="#FFB6C1"/>
    
    <!-- Smile -->
    <path
        android:pathData="M75,120 Q82,125 88,120"
        android:strokeColor="#333333"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    
    <!-- Tail (wrapped around) -->
    <path
        android:pathData="M160,140 Q170,120 150,110 Q130,100 110,120"
        android:strokeColor="#F59E0B"
        android:strokeWidth="12"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    
    <!-- Zzz -->
    <path
        android:pathData="M135,75 L145,75 L135,85 L145,85"
        android:strokeColor="#00FF88"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M150,60 L158,60 L150,68 L158,68"
        android:strokeColor="#00FF88"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M162,50 L168,50 L162,56 L168,56"
        android:strokeColor="#00FF88"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    
</vector>
